# Use an <ip-with-dashes>.sslip.io hostname — it maps directly to the VM's public IP,
# needs no DNS account/token, and is reliable for Let's Encrypt validation.
# Example: VM IP 34.100.254.11  ->  34-100-254-11.sslip.io
# Caddy auto-obtains and renews the TLS cert, as long as ports 80 and 443 are open.
YOUR-IP-WITH-DASHES.sslip.io {
    encode gzip
    reverse_proxy 127.0.0.1:8000
}
